<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar dengan tombol back -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarDetail"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#212121"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <!-- Konten scrollable -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER HIJAU (gambar + nama) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#2E7D32"
                android:paddingTop="28dp"
                android:paddingBottom="24dp">

                <!-- Kartu putih berisi emoji buah -->
                <FrameLayout
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:background="@drawable/bg_fruit_image_card">

                    <TextView
                        android:id="@+id/tvDetailEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textSize="96sp"
                        android:text="🍊" />
                </FrameLayout>

                <!-- Nama buah (putih, bold) -->
                <TextView
                    android:id="@+id/tvDetailNama"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Jeruk"
                    android:textSize="28sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- ===== BARIS INFO: ASAL & RASA ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!-- Asal -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌍 Asal"
                        android:textSize="12sp"
                        android:textColor="#757575" />

                    <TextView
                        android:id="@+id/tvDetailAsal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Asia Selatan"
                        android:textSize="14sp"
                        android:textColor="#212121"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Garis pemisah vertikal -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:minHeight="40dp"
                    android:background="#E0E0E0" />

                <!-- Rasa -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😋 Rasa"
                        android:textSize="12sp"
                        android:textColor="#757575" />

                    <TextView
                        android:id="@+id/tvDetailRasa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Manis-asam segar"
                        android:textSize="14sp"
                        android:textColor="#212121"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

            </LinearLayout>

            <!-- Spacer -->
            <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#F0F0F0" />

            <!-- ===== DESKRIPSI ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖 Deskripsi"
                    android:textSize="16sp"
                    android:textColor="#388E3C"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E8F5E9"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvDetailDeskripsi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="#424242"
                    android:lineSpacingMultiplier="1.6" />

            </LinearLayout>

            <!-- Spacer -->
            <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#F0F0F0" />

            <!-- ===== MANFAAT KESEHATAN ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Manfaat Kesehatan"
                    android:textSize="16sp"
                    android:textColor="#388E3C"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E8F5E9"
                    android:layout_marginBottom="10dp" />

                <!-- Diisi secara dinamis dari Java -->
                <LinearLayout
                    android:id="@+id/containerManfaat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
